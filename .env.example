# SwiftPay backend (Spring Boot service)
# Used in dev by Vite's /api/v1 proxy.
VITE_API_BASE_URL=http://localhost:9771

# OAuth2 client credentials for token issuance
VITE_CLIENT_ID=swiftpay-web-dev
VITE_CLIENT_SECRET=replace-me

# Optional: human-friendly env label shown in the UI footer
VITE_ENV_LABEL=local
